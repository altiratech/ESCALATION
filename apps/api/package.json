{
  "name": "@wargames/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev src/index.ts --port 8787 --local",
    "build": "tsc -p tsconfig.json --noEmit",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "deploy": "wrangler deploy",
    "db:migrate": "wrangler d1 execute escalation-db --local --file=../../db/migrations/0001_init.sql && wrangler d1 execute escalation-db --local --file=../../db/migrations/0002_tracking_analytics.sql",
    "db:seed": "wrangler d1 execute escalation-db --local --file=../../db/seed/seed.sql"
  },
  "dependencies": {
    "@wargames/content": "0.1.0",
    "@wargames/engine": "0.1.0",
    "@wargames/shared-types": "0.1.0",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.7.4",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250224.0",
    "drizzle-kit": "^0.30.4",
    "wrangler": "^4.4.0"
  }
}
